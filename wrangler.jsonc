{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "nu-bi",
  "main": ".worker-next/index.mjs",
  "compatibility_date": "2024-12-30",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "assets": {
    "directory": ".worker-next/assets",
    "binding": "ASSETS"
  },
  "vars": {
    "NODE_ENV": "production",
    "CLOUDFLARE_ENV": "production",
    "NEXT_PUBLIC_APP_URL": "https://nu-bi.com",
    "DATABASE_DRIVER": "d1",
    "STORAGE_DRIVER": "r2",
    "NEXT_PUBLIC_MEDIA_BASE_PATH": "/api/media",
    "SESSION_COOKIE_NAME": "nubi_session",
    "SESSION_MAX_AGE_DAYS": "14",
    "OPENAI_BASE_URL": "https://api.openai.com/v1",
    "OPENAI_TEXT_MODEL": "gpt-4.1-mini",
    "OPENAI_IMAGE_MODEL": "gpt-image-1-mini",
    "AI_AGENT_ADMIN_USERNAMES": "nubi"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "nu-bi",
      "database_id": "673b135d-6b56-44f9-801f-b87c0826a89a",
      "migrations_dir": "db/migrations"
    }
  ],
  "r2_buckets": [
    {
      "binding": "MEDIA",
      "bucket_name": "nu-bi-media",
      "preview_bucket_name": "nu-bi-media-preview"
    }
  ],
  "env": {
    "preview": {
      "vars": {
        "NODE_ENV": "production",
        "CLOUDFLARE_ENV": "preview",
        "NEXT_PUBLIC_APP_URL": "https://nu-bi-preview.cedricfjohnson.workers.dev",
        "DATABASE_DRIVER": "d1",
        "STORAGE_DRIVER": "r2",
        "NEXT_PUBLIC_MEDIA_BASE_PATH": "/api/media",
        "SESSION_COOKIE_NAME": "nubi_session",
        "SESSION_MAX_AGE_DAYS": "14",
        "OPENAI_BASE_URL": "https://api.openai.com/v1",
        "OPENAI_TEXT_MODEL": "gpt-4.1-mini",
        "OPENAI_IMAGE_MODEL": "gpt-image-1-mini",
        "AI_AGENT_ADMIN_USERNAMES": "nubi"
      },
      "d1_databases": [
        {
          "binding": "DB",
          "database_name": "nu-bi-preview",
          "database_id": "3c1cdf38-d5b0-43c6-a57d-1ba82a41e8cf",
          "migrations_dir": "db/migrations"
        }
      ],
      "r2_buckets": [
        {
          "binding": "MEDIA",
          "bucket_name": "nu-bi-media-preview",
          "preview_bucket_name": "nu-bi-media-preview"
        }
      ]
    }
  }
}
