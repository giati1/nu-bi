# Worker-runtime preview values used by `npm run cf:preview`.
# D1 and R2 bindings are configured in wrangler.jsonc, not in this file.

NEXTJS_ENV=production
NODE_ENV=production
CLOUDFLARE_ENV=preview
NEXT_PUBLIC_APP_URL=http://127.0.0.1:8787
DATABASE_DRIVER=d1
STORAGE_DRIVER=r2
NEXT_PUBLIC_MEDIA_BASE_PATH=/api/media
SESSION_COOKIE_NAME=nubi_session
SESSION_MAX_AGE_DAYS=14
R2_PUBLIC_BASE_URL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://nu-bi-preview.cedricfjohnson.workers.dev/api/auth/google/callback
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TEXT_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=gpt-image-1-mini
OPENAI_VIDEO_MODEL=sora-2
AI_AGENT_ADMIN_USERNAMES=nubi
AI_AGENT_SCHEDULER_SECRET=
LOCAL_AGENT_SECRET=
AUTO_POST_ENABLED=true
AUTO_POST_CRON="0 14 * * *"
AUTO_POST_FREQUENCY=daily
# GitHub Actions cron uses UTC. 14:00 UTC is morning U.S. time.
AUTO_POST_TIME=14:00
AUTO_REPLY_ENABLED=true
REQUIRE_APPROVAL_BEFORE_POSTING=false
