NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:8000

# Local development defaults
DATABASE_DRIVER=sqlite
DATABASE_PATH=./db/local.sqlite
STORAGE_DRIVER=local
UPLOADS_DIR=./public/uploads
NEXT_PUBLIC_STORAGE_BASE_PATH=/uploads
NEXT_PUBLIC_MEDIA_BASE_PATH=/api/media

# Auth/session
SESSION_COOKIE_NAME=nubi_session
SESSION_MAX_AGE_DAYS=14

# Cloudflare deployment values
CLOUDFLARE_ENV=production
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_D1_DATABASE_ID=
CLOUDFLARE_D1_DATABASE_NAME=nu-bi
CLOUDFLARE_R2_BUCKET=nu-bi-media
CLOUDFLARE_R2_PREVIEW_BUCKET=nu-bi-media-preview
R2_PUBLIC_BASE_URL=

# Optional OAuth / AI
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TEXT_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=gpt-image-1-mini
