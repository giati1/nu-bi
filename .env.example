# Local Node development (.env.local)
# Cloudflare bindings such as DB and MEDIA come from wrangler.jsonc, not this file.

NODE_ENV=development
PORT=8000
NEXT_PUBLIC_APP_URL=http://localhost:8000

# Local database and storage
DATABASE_DRIVER=sqlite
DATABASE_PATH=./db/local.sqlite
STORAGE_DRIVER=local
UPLOADS_DIR=./public/uploads
NEXT_PUBLIC_STORAGE_BASE_PATH=/uploads
NEXT_PUBLIC_MEDIA_BASE_PATH=/api/media

# Auth/session
SESSION_COOKIE_NAME=nubi_session
SESSION_MAX_AGE_DAYS=14

# Optional public R2 domain for production media URLs
R2_PUBLIC_BASE_URL=

# Optional integrations
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TEXT_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=gpt-image-1-mini
OPENAI_VIDEO_MODEL=sora-2

# Internal AI agent controls
AI_AGENT_ADMIN_USERNAMES=nubi
AI_AGENT_SCHEDULER_SECRET=
LOCAL_AGENT_SECRET=
AUTO_POST_ENABLED=true
AUTO_POST_CRON="0 14 * * *"
AUTO_POST_FREQUENCY=daily
# GitHub Actions cron uses UTC. 14:00 UTC is morning U.S. time.
AUTO_POST_TIME=14:00
AUTO_REPLY_ENABLED=true
REQUIRE_APPROVAL_BEFORE_POSTING=false
