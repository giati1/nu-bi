{
  "name": "nu-bi",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18.14.0"
  },
  "scripts": {
    "dev": "node scripts/run-next.mjs dev",
    "build": "next build",
    "start": "node scripts/run-next.mjs start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run build",
    "db:init": "tsx scripts/init-db.ts",
    "db:seed": "tsx scripts/seed.ts",
    "cf:preflight": "node scripts/require-node.mjs 20.3.0",
    "cf:build": "npm run cf:preflight && opennextjs-cloudflare build",
    "cf:preview": "npm run cf:build && wrangler dev --env preview",
    "cf:deploy": "npm run cf:build && wrangler deploy",
    "cf:deploy:preview": "npm run cf:build && wrangler deploy --env preview",
    "cf:typegen": "npm run cf:preflight && wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "cf:migrate:production": "npm run cf:preflight && wrangler d1 migrations apply nu-bi --remote",
    "cf:migrate:preview": "npm run cf:preflight && wrangler d1 migrations apply nu-bi-preview --remote --env preview",
    "d1:create": "wrangler d1 create nu-bi",
    "d1:create:preview": "wrangler d1 create nu-bi-preview",
    "r2:create": "wrangler r2 bucket create nu-bi-media",
    "r2:create:preview": "wrangler r2 bucket create nu-bi-media-preview"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "jose": "^5.9.6",
    "lucide-react": "^0.511.0",
    "next": "^13.5.11",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sqlite3": "^5.1.7",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.0.0",
    "@types/node": "^22.14.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "wrangler": "^4.11.1"
  }
}
